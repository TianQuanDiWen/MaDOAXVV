{
    "interface_version": 2,
    "name": "MaDOAXVV",
    "description": "DEAD OR ALIVE Xtreme Venus Vacation 自动化项目。",
    "contact": "",
    "license": "MIT",
    "welcome": "欢迎使用 MaDOAXVV。",
    "github": "https://github.com/TianQuanDiWen/MaDOAXVV",
    "version": "0.1.0",
    "controller": [
        {
            "name": "桌面端",
            "type": "Win32",
            "win32": {
                "class_regex": ".*",
                "window_regex": "DOAX VenusVacation",
                "screencap": "FramePool",
                "mouse": "PostMessageWithCursorPos",
                "keyboard": "PostMessageWithCursorPos"
            }
        }
    ],
    "resource": [
        {
            "name": "官服",
            "path": [
                "./resource"
            ]
        }
    ],
    "task": [
        {
            "name": "自动打新比赛",
            "entry": "新比赛_开始",
            "description": "有新比赛的情况下会自动打，直到打不过为止"
        },
        {
            "name": "自动排位",
            "entry": "排位_开始",
            "description": "自动打排位赛，打够次数为止"
        },
        {
            "name": "每日自动挑战券",
            "entry": "每日挑战_开始",
            "description": "每日自动领取挑战券，用自动战斗打三次，只认SS级自动挑战券"
        },
        {
            "name": "每日活动挑战赛",
            "entry": "日活动赛_开始",
            "description": "每日自动参与活动挑战赛，用自动挑战券打，目前只识别sss+"
        },
        {
            "name": "抽免费券",
            "entry": "抽免费券_开始",
            "description": "会自动抽免费券，判断依据是扭蛋图标旁边的免费文字（通过文字识别）"
        },
        {
            "name": "岛主房间",
            "entry": "岛主房间_开始",
            "description": "自动领温泉并补充温泉剂，工作完成自动收菜并继续工作"
        },
        {
            "name": "领取邮件与任务奖励",
            "entry": "领取_开始",
            "description": "领取邮件和任务奖励"
        },
        {
            "name": "赌场",
            "entry": "赌场_开始",
            "description": "打满赌场奖励，流程还在测试中"
        }
    ]
}
